# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/worldcup26

# ── Auth ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Live match engine (Phase 9) ─────────────────────────
# Auto-advances live matches and broadcasts realtime updates over Socket.io.
LIVE_ENGINE=on              # set to "off" to disable
LIVE_TICK_MS=5000           # real milliseconds per simulated match-minute
LIVE_MAX=8                  # max concurrently-driven matches
LIVE_AUTOKICKOFF=off        # "on" promotes scheduled matches to live at kickoff
