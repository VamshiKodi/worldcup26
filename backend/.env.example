# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/worldcup26

# ── Auth ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Live match engine (Phase 9) ─────────────────────────
# Auto-advances live matches and broadcasts realtime updates over Socket.io.
# Used only when FOOTBALL_DATA_TOKEN is NOT set (otherwise real data drives live updates).
LIVE_ENGINE=on              # set to "off" to disable
LIVE_TICK_MS=5000           # real milliseconds per simulated match-minute
LIVE_MAX=8                  # max concurrently-driven matches
LIVE_AUTOKICKOFF=off        # "on" promotes scheduled matches to live at kickoff

# ── Real World Cup data: football-data.org ──────────────
# Get a free token at https://www.football-data.org/client/register . When set,
# `npm run import:wc` loads real teams/fixtures/standings/form (+ scorers with --players),
# and the server polls live fixtures, replacing the simulated engine.
# Note: free tier delivers DELAYED (not tick-by-tick) live scores; 10 requests/min.
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=WC  # FIFA World Cup
FOOTBALL_DATA_POLL_MS=60000   # live-sync poll interval (ms); ≥30s enforced
FOOTBALL_DATA_RESULT_POLL_MS=300000  # finished-result reconcile interval (ms); ≥60s enforced
FOOTBALL_DATA_STATIC_POLL_MS=600000  # teams/standings/scorers refresh interval (ms); ≥120s enforced
